# Document Intelligence Refinery - Environment Variables

# Gemini API Key (for vision-augmented extraction)
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# OCR Engines (Optional - for handwriting recognition)
# Only configure if you need handwriting OCR

# Azure Computer Vision (Enterprise OCR)
# Get from: https://portal.azure.com → Create Computer Vision resource
# AZURE_CV_KEY=your_azure_key_here
# AZURE_CV_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# Google Cloud Vision (High-accuracy OCR)
# Get from: https://console.cloud.google.com → Enable Vision API → Create Service Account
# Save JSON key file to ~/.gcp/ and set path below
# GOOGLE_APPLICATION_CREDENTIALS=/home/yourusername/.gcp/your-key-file.json

# Optional: Other API Keys
# OPENROUTER_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here
# DEEPSEEK_API_KEY=your_key_here
# GROQ_API_KEY=your_key_here

# Cost limits
MAX_COST_PER_DOCUMENT=1.0

# Confidence thresholds
CONFIDENCE_ESCALATION_THRESHOLD=0.7
